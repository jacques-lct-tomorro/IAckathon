ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Cookie auth: comma-separated usernames, one shared password, session signing secret
AUTH_USERS=alice,bob,charlie
AUTH_PASSWORD=changeme
SESSION_SECRET=some-random-string

# SQLite session file (persists across process restarts). On Fly with a volume, use e.g. /data/sessions.sqlite
SESSION_SQLITE_PATH=./data/sessions.sqlite

# Cookie: for SPA on another origin (Netlify + Fly), set SESSION_COOKIE_SAMESITE=none on the API
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_SECURE=
SESSION_MAX_AGE_MS=
